NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# Anthropic (lead scoring, generación)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# n8n self-hosted (Hetzner)
N8N_WEBHOOK_BASE=https://n8n.tu-dominio.com/webhook
N8N_OUTBOUND_SECRET=cambia-esto-largo-y-aleatorio
N8N_INBOUND_SECRET=cambia-esto-largo-y-aleatorio

# Auth
NEXT_PUBLIC_SITE_URL=http://localhost:3000
